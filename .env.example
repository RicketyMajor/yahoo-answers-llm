# ===== Base de Datos =====
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=yahoo_answers
DB_HOST=db
DB_PORT=5432
DB_NAME=yahoo_answers
DB_USER=admin
DB_PASS=your_password_here

# ===== Redis =====
REDIS_HOST=cache
REDIS_PORT=6379

# ===== LLM =====
GEMINI_API_KEY=your_gemini_api_key_here
MOCK_LLM=True

# ===== Cache Service =====
CACHE_TTL=3600
CACHE_MAX_MEMORY=2mb
CACHE_EVICTION_POLICY=allkeys-lru

# ===== Traffic Generator =====
DISTRIBUTION=poisson
RATE=10
TOTAL_REQUESTS=500

# ===== Seed =====
SEED_LIMIT=10000
